{
  "name": "lumina",
  "version": "1.0.0",
  "description": "",
  "main": "src/server.ts",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon --exec tsx src/server.ts",
    "dev:client": "vite",
    "build:client": "vite build",
    "build": "tsc && npm run build:client",
    "start": "node dist/server.js",
    "test": "vitest run",
    "migrate": "tsx scripts/migrate.ts up",
    "migrate:seed": "tsx scripts/migrate.ts up && tsx scripts/seed.ts",
    "migrate:undo": "tsx scripts/migrate.ts down",
    "migrate:reset": "tsx scripts/migrate.ts reset",
    "db:seed": "tsx scripts/seed.ts",
    "down": "tsx scripts/maintenance.ts down",
    "up": "tsx scripts/maintenance.ts up",
    "create:model": "tsx scripts/create-model.ts",
    "create:migration": "tsx scripts/create-migration.ts",
    "create:controller": "tsx scripts/create-controller.ts",
    "create:factory": "tsx scripts/create-factory.ts",
    "key:generate": "tsx scripts/generate-keys.ts"
  },
  "private": true,
  "type": "module",
  "dependencies": {
    "@inertiajs/react": "^3.6.0",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "inertia-node": "^2.0.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "mysql2": "^3.22.5",
    "nodemon": "^3.1.14",
    "pg": "^8.22.0",
    "pg-hstore": "^2.3.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sequelize": "^6.37.8",
    "sequelize-cli": "^6.6.5",
    "umzug": "^3.8.3",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.2.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
